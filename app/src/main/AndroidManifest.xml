<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <!-- ====================================================== -->
    <!-- 权限声明清单 (Permissions Manifest) -->
    <!-- 注意：标有[危险权限]的，必须在运行时动态向用户请求授权 -->
    <!-- ====================================================== -->

    <!-- *************** 1. 存储与文件访问权限 (Storage & File Access) *************** -->
    <!--
        Android 10+ 引入了作用域存储 (Scoped Storage)。
        WRITE_EXTERNAL_STORAGE 在 targetSdkVersion >= 29 的应用中功能被大幅限制。
        建议使用 MediaStore API 和 Storage Access Framework (SAF)。
    -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <!-- [危险权限] 读取外部共享存储（如图片、音乐、下载文件夹）。Android 13+ 媒体权限被细分为 READ_MEDIA_IMAGES/VIDEO/AUDIO -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="32" tools:ignore="ScopedStorage" />
    <!-- [危险权限] 写入外部共享存储。对于 targetSdkVersion >= 30 的应用，此权限在大多数情况下已被废弃，主要兼容旧系统。 -->

    <!-- *************** 2. 位置与地理定位权限 (Location & Geolocation) *************** -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- [危险权限] 通过 GPS/Wi-Fi/移动网络获取精确位置（米级精度） -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- [危险权限] 通过基站/Wi-Fi 获取大致位置（百米/公里级精度） -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <!-- [危险权限] 后台位置访问。从 Android 10 开始，用户必须在系统设置中手动授予。 -->

    <!-- *************** 3. 摄像头与音频权限 (Camera & Audio) *************** -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- [危险权限] 访问摄像头硬件，用于拍照、录像、扫码、视频通话 -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- [危险权限] 访问麦克风，用于录音、语音通话、语音识别 -->

    <!-- *************** 4. 联系人权限 (Contacts) *************** -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <!-- [危险权限] 读取设备联系人（姓名、电话、邮箱等） -->
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />
    <!-- [危险权限] 创建、修改、删除设备联系人。高风险权限，请谨慎使用。 -->

    <!-- *************** 5. 电话与通讯权限 (Telephony & Communication) *************** -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <!-- [危险权限] 读取手机状态和身份（如 IMEI、通话状态、电话号码） -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <!-- [危险权限] 允许应用直接拨打电话，无需用户确认。 -->
    <uses-permission android:name="android.permission.SEND_SMS" />
    <!-- [危险权限] 发送短信。高敏感权限，易被滥用。 -->

    <!-- *************** 6. 网络与连接权限 (Network & Connectivity) *************** -->
    <!--
        [非危险权限] 以下权限通常不需要运行时动态申请，安装时自动授予。
        但应用在实际使用相关功能前，仍需在清单文件中声明。
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 基本网络访问，允许应用打开网络套接字 -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- 获取 Wi-Fi 连接状态和信息，可用于网络定位 -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- 获取网络状态（如是否连接、连接类型），获取运营商信息 -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <!-- 允许应用改变 Wi-Fi 连接状态（如打开/关闭 Wi-Fi、连接到网络） -->

    <!-- *************** 7. 通知权限 (Notifications) *************** -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- [危险权限] (Android 13+) 发送通知。从 Android 13 开始，需要动态请求。 -->

    <!-- *************** 8. 系统与电源管理权限 (System & Power Management) *************** -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- 允许应用在屏幕关闭后保持 CPU 运行，或防止屏幕变暗/锁屏。 -->
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />
    <!-- 允许应用杀死其他应用的后台进程。高权限操作，需谨慎使用。 -->

    <!-- *************** 9. usb 权限 *************** -->
    <uses-permission android:name="android.permission.USB_PERMISSION" />

    <application
        android:name="com.example.myglidehelper.MyApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyGlideHelper"
        tools:targetApi="31" >

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>